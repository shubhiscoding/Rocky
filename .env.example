# ============================================================
# Rocky — AUDD Agent on Solana
# Copy this file to .env.local and fill in the values.
# ============================================================

# ------------------------------------------------------------
# Privy (auth + embedded wallets)
# https://console.privy.io → App → Settings
# ------------------------------------------------------------
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Optional: required only if you enable server-side Privy signing
# https://docs.privy.io/guide/server/authorization-keys
PRIVY_SIGNING_KEY=

# ------------------------------------------------------------
# AI — at least ANTHROPIC or OPENAI required
# ------------------------------------------------------------

# Primary LLM (Claude 3.5 Sonnet) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Orchestrator + fallback (GPT-4o / gpt-4o-mini)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: override the OpenAI-compatible endpoint and model
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4o

# ------------------------------------------------------------
# Database (PostgreSQL via Prisma)
# Use separate connection-pooler URL (e.g. Supabase pgBouncer)
# and direct URL for migrations.
# ------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:6543/db?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/db

# ------------------------------------------------------------
# Helius (Solana RPC + portfolio data)
# https://dev.helius.xyz
# ------------------------------------------------------------
NEXT_PUBLIC_HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
HELIUS_API_KEY=

# ------------------------------------------------------------
# Wallet encryption
# Used to encrypt embedded wallet private keys stored in the DB.
# Generate with: openssl rand -base64 32
# WARNING: never change this after wallets have been created.
# ------------------------------------------------------------
WALLET_ENCRYPTION_KEY=

# ------------------------------------------------------------
# Solana network
# Use "devnet" for testing, "mainnet-beta" for production.
# ------------------------------------------------------------
NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# ------------------------------------------------------------
# AUDD token
# Default is the mainnet mint — override only if using a custom devnet mint.
# Mainnet: https://solscan.io/token/AUDDttiEpCydTm7joUMbYddm72jAWXZnCpPZtDoxqBSw
# ------------------------------------------------------------
NEXT_PUBLIC_AUDD_MINT=AUDDttiEpCydTm7joUMbYddm72jAWXZnCpPZtDoxqBSw

# ------------------------------------------------------------
# Feature flags (optional)
# ------------------------------------------------------------

# JSON array of tool names to disable, e.g. '["swapAudd","investAudd"]'
NEXT_PUBLIC_DISABLED_TOOLS=[]

# Subscription gate — set false to let all users in (default for MVP)
NEXT_PUBLIC_SUB_ENABLED=false
NEXT_PUBLIC_SUB_LAMPORTS=0

# Trial gate — set false to skip trial flow (default for MVP)
NEXT_PUBLIC_TRIAL_ENABLED=false
NEXT_PUBLIC_TRIAL_LAMPORTS=0
